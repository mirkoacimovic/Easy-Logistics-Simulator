@* @page "/"
@using EasyLogistics.Telemetry.System.Core.Models
@using EasyLogistics.Telemetry.System.Core.Interfaces
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Nav
@inject IFleetStateService StateService
@implements IAsyncDisposable
@rendermode InteractiveServer

<div class="dashboard-header d-flex justify-content-between align-items-end mb-4 border-bottom border-secondary pb-3">
    <div>
        <h2 class="text-white fw-bold mb-0 tracking-tighter">FLEET <span class="text-primary">OPS</span></h2>
        <span class="badge bg-primary-subtle text-primary border border-primary px-3">NETWORK LIVE</span>
    </div>
    <div class="text-end">
        <div class="small text-muted text-uppercase fw-bold">System Status</div>
        <div class="d-flex align-items-center gap-2">
            <div class="pulse-dot @(isConnected ? "bg-success" : "bg-danger")"></div>
            <span class="text-white font-monospace small">@(isConnected ? "ENCRYPTED_LINK" : "SIGNAL_LOSS")</span>
        </div>
    </div>
</div>

<div class="row g-3">
    @if (_trucks != null && _trucks.Any())
    {
        @foreach (var truck in _trucks)
        {
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="card bg-black border-secondary telemetry-card shadow-sm">
                    <div class="card-header border-secondary d-flex justify-content-between align-items-center py-2">
                        <span class="text-primary font-monospace fw-bold small">ID // @truck.TruckId.ToString("D3")</span>
                        <span class="badge @(truck.Speed > 0 ? "bg-success" : "bg-warning") text-black fw-bold" style="font-size: 0.65rem;">
                            @(truck.Speed > 0 ? "MOVING" : "STATIONARY")
                        </span>
                    </div>
                    <div class="card-body py-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="text-muted small fw-bold">VELOCITY</span>
                            <span class="text-white h4 mb-0 font-monospace">@truck.Speed.ToString("F1")</span>
                        </div>
                        <div class="progress bg-dark mb-3" style="height: 4px;">
                            <div class="progress-bar bg-primary shadow-glow" style="width: @(Math.Min(truck.Speed, 100))%"></div>
                        </div>
                        <div class="row g-2 text-center">
                            <div class="col-6">
                                <div class="bg-dark rounded py-2 border border-secondary-subtle">
                                    <div class="text-muted small-xs fw-bold">FUEL</div>
                                    <div class="text-white small">@truck.FuelConsumed.ToString("F1") L</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-dark rounded py-2 border border-secondary-subtle">
                                    <div class="text-muted small-xs fw-bold">ODO</div>
                                    <div class="text-white small">@truck.DistanceTraveled.ToString("F0") KM</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer border-secondary py-1 bg-transparent">
                        <code class="text-muted small-xs">POS: @truck.Latitude.ToString("F4") | @truck.Longitude.ToString("F4")</code>
                    </div>
                </div>
            </div>
        }
    }
</div>

<style>
    .telemetry-card {
        transition: transform 0.2s ease;
        cursor: default;
    }

        .telemetry-card:hover {
            transform: translateY(-3px);
            border-color: var(--bs-primary) !important;
        }

    .small-xs {
        font-size: 0.7rem;
    }

    .pulse-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .bg-success {
        box-shadow: 0 0 10px #198754;
    }

    .shadow-glow {
        box-shadow: 0 0 8px var(--bs-primary);
    }
</style>

@code {
    private HubConnection? _hubConnection;
    private List<TruckDisplayVm> _trucks = new();
    private bool isConnected => _hubConnection?.State == HubConnectionState.Connected;

    protected override async Task OnInitializedAsync()
    {
        // 1. Load data immediately from the Singleton (Prevents spinner on nav)
        _trucks = StateService.GetFormattedFleet();

        // 2. Build SignalR Connection
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/fleethub"))
            .WithAutomaticReconnect(new[] { TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5) })
            .Build();

        // 3. Listen for live updates
        _hubConnection.On<List<TruckDisplayVm>>("ReceiveFleetUpdate", (data) =>
        {
            _trucks = data;
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null) 
        {
            await _hubConnection.DisposeAsync();
        }
    }
} *@

@page "/"
@using EasyLogistics.Telemetry.System.Core.Models
@using EasyLogistics.Telemetry.System.Core.Interfaces
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Nav
@inject IFleetStateService StateService
@implements IAsyncDisposable
@rendermode InteractiveServer

@{
    // We define the keyframes as a string to hide the @ symbols from the CSS validator
    var keyframes = @"
        @keyframes pulse-animation {
            0% { opacity: 1; }
            50% { opacity: 0.4; }
            100% { opacity: 1; }
        }";
}

<div class="dashboard-header d-flex justify-content-between align-items-end mb-4 border-bottom border-secondary pb-3">
    <div>
        <h2 class="text-white fw-bold mb-0 tracking-tighter">FLEET <span class="text-primary">OPS</span></h2>
        <span class="badge bg-primary-subtle text-primary border border-primary px-3">NETWORK LIVE</span>
    </div>
    <div class="text-end">
        <div class="small text-muted text-uppercase fw-bold">System Status</div>
        <div class="d-flex align-items-center gap-2">
            <div class="pulse-dot @(isConnected ? "bg-success" : "bg-danger")"></div>
            <span class="text-white font-monospace small">@(isConnected ? "ENCRYPTED_LINK" : "SIGNAL_LOSS")</span>
        </div>
    </div>
</div>

<div class="row g-3">
    @if (_trucks != null && _trucks.Any())
    {
        @foreach (var truck in _trucks)
        {
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="card bg-black border-secondary telemetry-card shadow-sm">
                    <div class="card-header border-secondary d-flex justify-content-between align-items-center py-2">
                        <span class="text-primary font-monospace fw-bold small">ID // @truck.TruckId.ToString("D3")</span>
                        <span class="badge @(truck.Speed > 0 ? "bg-success" : "bg-warning") text-black fw-bold" style="font-size: 0.65rem;">
                            @(truck.Speed > 0 ? "MOVING" : "STATIONARY")
                        </span>
                    </div>
                    <div class="card-body py-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="text-muted small fw-bold">VELOCITY</span>
                            <span class="text-white h4 mb-0 font-monospace">@truck.Speed.ToString("F1") <small class="text-muted" style="font-size: 0.6rem;">KM/H</small></span>
                        </div>
                        <div class="progress bg-dark mb-3" style="height: 4px;">
                            <div class="progress-bar bg-primary shadow-glow" style="width: @(Math.Min(truck.Speed, 100))%"></div>
                        </div>
                        <div class="row g-2 text-center">
                            <div class="col-6">
                                <div class="bg-dark rounded py-2 border border-secondary-subtle">
                                    <div class="text-muted small-xs fw-bold">FUEL</div>
                                    <div class="text-white small">@truck.FuelConsumed.ToString("F1") L</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-dark rounded py-2 border border-secondary-subtle">
                                    <div class="text-muted small-xs fw-bold">ODO</div>
                                    <div class="text-white small">@truck.DistanceTraveled.ToString("F0") KM</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer border-secondary py-1 bg-transparent">
                        <code class="text-muted small-xs">POS: @truck.Latitude.ToString("F4") | @truck.Longitude.ToString("F4")</code>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <div class="text-muted mt-3 font-monospace">SCANNING_SHM_RESERVES...</div>
        </div>
    }
</div>

<style>
    .telemetry-card {
        transition: transform 0.2s ease, border-color 0.2s ease;
        cursor: default;
    }

        .telemetry-card:hover {
            transform: translateY(-3px);
            border-color: var(--bs-primary) !important;
        }

    .small-xs {
        font-size: 0.7rem;
    }

    .pulse-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        animation: pulse-animation 2s infinite;
    }

    /* Injecting the keyframes string here as raw HTML */
    @((MarkupString)keyframes)

    .bg-success {
        box-shadow: 0 0 10px #198754;
    }

    .shadow-glow {
        box-shadow: 0 0 8px var(--bs-primary);
    }
</style>

@code {
    private HubConnection? _hubConnection;
    private List<TruckDisplayVm> _trucks = new();
    private bool isConnected => _hubConnection?.State == HubConnectionState.Connected;

    protected override async Task OnInitializedAsync()
    {
        _trucks = StateService.GetFormattedFleet() ?? new();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/fleethub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<List<TruckDisplayVm>>("ReceiveFleetUpdate", (data) =>
        {
            _trucks = data;
            InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SignalR Error: {ex.Message}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}