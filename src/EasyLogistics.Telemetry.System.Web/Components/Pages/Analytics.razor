@page "/analytics"
@using EasyLogistics.Telemetry.System.Core.Models
@using EasyLogistics.Telemetry.System.Core.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@attribute [Authorize]
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IFleetStateService StateService
@implements IAsyncDisposable
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<div class="container-fluid py-4 bg-black min-vh-100 text-white font-monospace">
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom border-secondary pb-3">
        <div>
            <h2 class="fw-black text-uppercase tracking-tighter m-0">FUEL_<span class="text-danger">ANALYTICS</span></h2>
            <small class="text-muted">OPERATIONAL EFFICIENCY REPORT</small>
        </div>
        <div class="text-end">
            <div class="small text-muted mb-1">DATA_BRIDGE</div>
            <span class="badge @(IsConnected ? "bg-danger" : "bg-dark") border border-danger">@(IsConnected ? "STREAMING" : "OFFLINE")</span>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-9">
            <div class="card bg-black border-secondary h-100 shadow-sm">
                <div class="card-header border-secondary d-flex justify-content-between">
                    <span class="text-muted small fw-bold uppercase">Consumption_By_Unit</span>
                    <span class="text-danger small">LIVE_CANVAS</span>
                </div>
                <div class="card-body">
                    <div style="height: 450px; position: relative;">
                        <canvas id="fuelChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3">
            <div class="card bg-black border-danger mb-4">
                <div class="card-body">
                    <label class="text-muted small d-block">FLEET_CONSUMPTION</label>
                    <span class="h2 text-danger fw-bold">@_latestFleet.Sum(t => t.FuelConsumed).ToString("F1")</span>
                    <small class="text-muted">L</small>
                </div>
            </div>

            <div class="card bg-black border-secondary">
                <div class="card-header border-secondary py-2">
                    <span class="text-muted small fw-bold">TOP_CONSUMERS</span>
                </div>
                <div class="list-group list-group-flush">
                    @foreach (var truck in _latestFleet.OrderByDescending(t => t.FuelConsumed).Take(8))
                    {
                        <div class="list-group-item bg-transparent text-white border-secondary border-opacity-25 py-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="small">#@truck.TruckId.ToString("D3")</span>
                                <span class="text-danger fw-bold small">@truck.FuelConsumed.ToString("F1") L</span>
                            </div>
                            <div class="progress mt-1" style="height: 2px; background: #111;">
                                <div class="progress-bar bg-danger" style="width: @(GetFuelPercentage(truck.FuelConsumed))%"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<TruckDisplayVm> _latestFleet = new();
    private HubConnection? _hubConnection;
    private bool _chartReady = false;
    private bool IsConnected => _hubConnection?.State == HubConnectionState.Connected;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initial snapshot from the Singleton Service
            _latestFleet = StateService.GetFormattedFleet();
            if (_latestFleet.Any()) await UpdateChart();

            _hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/fleethub"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<List<TruckDisplayVm>>("ReceiveFleetUpdate", async (data) =>
            {
                _latestFleet = data;
                await UpdateChart();
                await InvokeAsync(StateHasChanged);
            });

            await _hubConnection.StartAsync();
        }
    }

    private async Task UpdateChart()
    {
        try
        {
            var labels = _latestFleet.Select(t => $"U-{t.TruckId:D3}").ToArray();
            var values = _latestFleet.Select(t => t.FuelConsumed).ToArray();

            if (!_chartReady)
            {
                await JS.InvokeVoidAsync("initChart", labels, values);
                _chartReady = true;
            }
            else
            {
                await JS.InvokeVoidAsync("updateChart", labels, values);
            }
        }
        catch (Exception ex) { Console.WriteLine($"Analytics Fail: {ex.Message}"); }
    }

    private double GetFuelPercentage(double current)
    {
        var max = _latestFleet.Any() ? _latestFleet.Max(x => x.FuelConsumed) : 100;
        return (current / (max > 0 ? max : 1)) * 100;
    }

    public async ValueTask DisposeAsync() => await (_hubConnection?.DisposeAsync() ?? ValueTask.CompletedTask);
}