@page "/fleet-map"
@using Microsoft.AspNetCore.SignalR.Client
@using EasyLogistics.Telemetry.System.Core.Models
@using EasyLogistics.Telemetry.System.Core.Interfaces
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IFleetStateService StateService
@implements IAsyncDisposable
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<div id="map" style="height: 100vh; width: 100%; background: #000;"></div>

@code {
    private HubConnection? _hubConnection;
    private string _lastSync = "WAITING";
    private bool IsConnected => _hubConnection?.State == HubConnectionState.Connected;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // 1. Initialize Leaflet (Center on Belgrade)
                await JS.InvokeVoidAsync("mapInterop.initialize", 44.8186, 20.4689);

                // 2. Immediate Hydration from Memory
                var snapshot = StateService.GetFormattedFleet();
                if (snapshot != null && snapshot.Any())
                {
                    await JS.InvokeVoidAsync("mapInterop.updateTrucks", snapshot);
                    _lastSync = "INIT_SYNC";
                }

                // 3. Connect to the Real-time Pipe
                _hubConnection = new HubConnectionBuilder()
                    .WithUrl(Nav.ToAbsoluteUri("/fleethub"))
                    .WithAutomaticReconnect()
                    .Build();

                _hubConnection.On<List<TruckDisplayVm>>("ReceiveFleetUpdate", async (data) =>
                {
                    _lastSync = DateTime.Now.ToString("HH:mm:ss");
                    // Push the list directly to the Leaflet marker manager
                    await JS.InvokeVoidAsync("mapInterop.updateTrucks", data);
                    await InvokeAsync(StateHasChanged);
                });

                await _hubConnection.StartAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Map Component Error]: {ex.Message}");
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null) 
        {
            await _hubConnection.DisposeAsync();
        }
    }
}