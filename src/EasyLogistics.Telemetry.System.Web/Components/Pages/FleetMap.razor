@page "/fleet-map"
@using EasyLogistics.Telemetry.System.Core.Interfaces
@using EasyLogistics.Telemetry.System.Core.Models
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IFleetStateService FleetService
@inject IJSRuntime JS
@implements IDisposable
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Live Map | Europe</PageTitle>

<div class="vh-100 d-flex flex-column bg-dark">
    @* Dashboard Mini-Header *@
    <div class="px-4 py-2 bg-black border-bottom border-secondary d-flex justify-content-between align-items-center">
        <h5 class="text-white mb-0 text-uppercase tracking-tighter fw-bold">
            <span class="text-primary">●</span> Live Fleet Tracking: Europe
        </h5>
        <div class="small text-muted">
            Last Heartbeat: @(_fleet.FirstOrDefault()?.LastUpdated.ToString("HH:mm:ss") ?? "Connecting...")
        </div>
    </div>

    @* Full Screen Map Container - Fixed Height is crucial for Leaflet *@
    <div id="map" class="flex-grow-1" style="background: #242424; min-height: 500px;"></div>
</div>

@code {
    private IEnumerable<TruckDisplayVm> _fleet = new List<TruckDisplayVm>();

    protected override void OnInitialized()
    {
        _fleet = FleetService.GetFormattedFleet();
        // Subscribe to the Infrastructure event loop
        FleetService.OnFleetUpdated += HandleFleetUpdate;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize Leaflet Map via JS Interop
            // Belgrade center: 44.8186, 20.4689
            await JS.InvokeVoidAsync("mapInterop.initialize", 44.8186, 20.4689);

            if (_fleet.Any())
            {
                await JS.InvokeVoidAsync("mapInterop.updateTrucks", _fleet);
            }
        }
    }

    private async void HandleFleetUpdate(List<TruckDisplayVm> newData)
    {
        // Must use InvokeAsync because this event comes from a background thread (FleetWorker)
        await InvokeAsync(async () =>
        {
            _fleet = newData;

            try
            {
                // Push new coordinates to the Leaflet markers
                await JS.InvokeVoidAsync("mapInterop.updateTrucks", _fleet);
            }
            catch (Exception)
            {
                // Silently handle if JS is not ready yet during navigation
            }

            StateHasChanged();
        });
    }

    public void Dispose()
    {
        // Unsubscribe to prevent memory leaks in the Singleton service
        FleetService.OnFleetUpdated -= HandleFleetUpdate;
    }
}