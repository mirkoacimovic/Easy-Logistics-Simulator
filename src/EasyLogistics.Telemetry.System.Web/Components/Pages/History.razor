@page "/history"
@using EasyLogistics.Telemetry.System.Core.Interfaces
@using EasyLogistics.Telemetry.System.Core.Models
@inject IFleetRepository Repository

<div class="container-fluid py-4 bg-black min-vh-100">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-2">
        <h2 class="text-white fw-light">
            <span class="live-indicator"></span>FLEET_<span class="text-info">AI</span>_TERMINAL <small class="text-muted fs-6">v1.0.5</small>
        </h2>
        <button class="btn btn-outline-info btn-sm font-monospace" @onclick="RefreshData">
            <i class="bi bi-arrow-repeat"></i> RE-SYNC
        </button>
    </div>

    <div class="row">
        @if (_history == null)
        {
            <div class="col-12 text-center p-5">
                <div class="spinner-border text-info mb-3" role="status"></div>
                <div class="text-muted font-monospace ls-1">SYNCHRONIZING_DATA_STREAM...</div>
            </div>
        }
        else if (!_history.Any())
        {
            <div class="col-12">
                <div class="alert alert-dark border-secondary text-center font-monospace">
                    <i class="bi bi-exclamation-triangle text-warning me-2"></i> NO_ARCHIVED_TELEMETRY_FOUND
                </div>
            </div>
        }
        else
        {
            @foreach (var truck in _history)
            {
                <div class="col-12 mb-2">
                    <div class="cyber-card p-3 d-flex flex-wrap justify-content-between align-items-center border border-secondary rounded bg-dark shadow-sm">
                        <div style="min-width: 120px;">
                            <div class="text-muted small ls-1">UNIT_ID</div>
                            <div class="h5 mb-0 text-primary font-monospace">#@truck.TruckId.ToString("D3")</div>
                        </div>

                        <div class="flex-grow-1 px-4">
                            <div class="text-muted small ls-1">AI_DIAGNOSTIC</div>
                            <div class="@truck.SeverityClass font-monospace">@truck.AiStatus</div>
                        </div>

                        <div class="text-center px-4">
                            <div class="text-muted small ls-1">VELOCITY</div>
                            <div class="text-white fw-bold font-monospace">@truck.Speed.ToString("F1") <small class="text-muted">KM/H</small></div>
                        </div>

                        <div class="text-center px-4">
                            <div class="text-muted small ls-1">ODOMETER</div>
                            <div class="text-white font-monospace">@truck.DistanceTraveled.ToString("F1") <small class="text-muted">KM</small></div>
                        </div>

                        <div class="text-end" style="min-width: 150px;">
                            <div class="text-muted small ls-1">LAST_PULSE</div>
                            <div class="text-info font-monospace">@truck.LastUpdated</div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .ls-1 {
        letter-spacing: 1px;
    }

    .live-indicator {
        display: inline-block;
        width: 10px;
        height: 10px;
        background-color: #10b981;
        border-radius: 50%;
        margin-right: 10px;
        box-shadow: 0 0 8px #10b981;
        animation: cyber-blink 2s infinite;
    }

    .cyber-card {
        background: rgba(30, 41, 59, 0.7);
        border-left: 4px solid #38bdf8;
        border-radius: 4px;
        margin-bottom: 1rem;
        padding: 1rem;
        transition: transform 0.2s;
    }

    .blink {
        animation: cyber-blink 1.5s infinite;
    }

    /* We inject the keyframes as a string so the CSS validator skips it */
    @((MarkupString)_cyberAnimation)
</style>

@code {

    private const string _cyberAnimation = @"
        @keyframes cyber-blink {
            from { opacity: 1.0; }
            50% { opacity: 0.3; }
            to { opacity: 1.0; }
        }";

    private IEnumerable<TruckDisplayVm>? _history;

    protected override async Task OnInitializedAsync()
    {
        await RefreshData();
    }

    private async Task RefreshData()
    {
        _history = null;
        // Force a small delay to show the terminal 'SYNCHRONIZING' feel
        await Task.Delay(300);
        _history = await Repository.GetLatestPositionsAsync();
    }
}