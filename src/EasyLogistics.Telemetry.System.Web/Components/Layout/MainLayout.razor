@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<div class="page">
    <AuthorizeView>
        <Authorized>
            @* The outer 'context' belongs to this AuthorizeView *@
            <div class="sidebar">
                <NavMenu />
            </div>

            <main>
                <div class="top-row px-4 border-bottom bg-white d-flex align-items-center justify-content-between">
                    <span class="fw-bold text-uppercase">Fleet Engine v1.0</span>

                    @* Rename the inner context to 'userContext' to avoid the conflict *@
                    <AuthorizeView Context="userContext">
                        <span class="text-muted small">
                            <i class="bi bi-person-circle me-1"></i>
                            User: @userContext.User.Identity?.Name
                        </span>
                    </AuthorizeView>
                </div>

                <article class="content px-4">
                    @Body
                </article>
            </main>
        </Authorized>
        <NotAuthorized>
            @* Use the full body for the Login page so it remains centered/black *@
            <main>
                @Body
            </main>
        </NotAuthorized>
    </AuthorizeView>
</div>