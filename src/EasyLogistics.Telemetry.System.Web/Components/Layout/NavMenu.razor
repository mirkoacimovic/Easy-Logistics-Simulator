@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row ps-3 navbar navbar-dark bg-dark shadow-sm">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold text-uppercase tracking-wider" href="">
            <span class="bi bi-truck-flatbed me-2 text-primary"></span>Fleet Command
        </a>
    </div>
</div>

<div class="nav-scrollable">
    <nav class="flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-speedometer2" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="fleet-map">
                        <span class="bi bi-map" aria-hidden="true"></span> Live Map
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="analytics">
                        <span class="bi bi-cpu" aria-hidden="true"></span> AI Analytics
                    </NavLink>
                </div>

                @* PRO ADDITION: History / Audit Trail *@
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="history">
                        <span class="bi bi-clock-history" aria-hidden="true"></span> Audit Trail
                    </NavLink>
                </div>

                <div class="nav-item px-3 mt-5 border-top border-secondary pt-3">
                    <div class="nav-link text-muted small mb-2">
                        <i class="bi bi-person-circle me-2"></i>@context.User.Identity?.Name
                    </div>
                    <NavLink class="nav-link text-danger logout-link" href="logout">
                        <span class="bi bi-box-arrow-right" aria-hidden="true"></span> Logout Session
                    </NavLink>
                </div>
            </Authorized>

            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">
                        <span class="bi bi-shield-lock" aria-hidden="true"></span> Authenticate
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>

    </nav>
</div>

<style>
    .tracking-wider {
        letter-spacing: 0.1rem;
    }

    .logout-link:hover {
        background-color: rgba(220, 53, 69, 0.1);
    }
</style>