@using EasyLogistics.Telemetry.System.Web.Components.Layout

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <RedirectToLogin />
                </NotAuthorized>
            </AuthorizeRouteView>
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <div class="container mt-5">
                    <div class="alert alert-danger shadow-sm bg-black border-danger text-danger">
                        <h4 class="fw-bold"><i class="bi bi-exclamation-octagon me-2"></i>404 - TERMINAL OFFLINE</h4>
                        <p>The requested telemetry module or page does not exist on this server.</p>
                        <hr class="border-danger">
                        <a href="/" class="btn btn-outline-danger btn-sm">Return to Command</a>
                    </div>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>